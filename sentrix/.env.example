# =============================================================================
# Sentrix – .env.example
# Copy to .env and fill in values. Not all variables are required; it depends
# on whether you use the wizard, --patrol, or pass -e KEY=VALUE to sentrix run.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenSandbox (optional)
# -----------------------------------------------------------------------------
# Path to opensandbox-server binary if not on PATH
# SENTRIX_OPENSANDBOX_SERVER=opensandbox-server

# -----------------------------------------------------------------------------
# Provider API key (required for sentrix run – set one, or use wizard)
# -----------------------------------------------------------------------------
# Used by OpenClaw in the sandbox. The wizard can detect these if set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=

# -----------------------------------------------------------------------------
# Patrol swarm (required only for sentrix run --patrol)
# -----------------------------------------------------------------------------
# Patrol uses OPENAI_API_KEY or ANTHROPIC_API_KEY above if set. Or use:
# PATROL_OPENAI_API_KEY=
# PATROL_ANTHROPIC_API_KEY=

# Model for patrol LLM (default: gpt-4o-mini with OpenAI, claude-* with Anthropic)
# PATROL_MODEL=gpt-4o-mini

# Bump these to re-review all logs (cleared state is version-based)
# PATROL_RULESET_VERSION=v1.0
# PATROL_MODEL_VERSION=

# Optional patrol tuning
# PATROL_CONFIDENCE_THRESHOLD=0.6
# PATROL_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Channels (optional – for Telegram, Discord, Slack bots)
# -----------------------------------------------------------------------------
# Set if you use the wizard and link a channel that needs a token.
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Web Search / Tools (optional)
# -----------------------------------------------------------------------------
# Brave Search API key – enables agent web search.
# Free tier: 2,000 queries/month at https://brave.com/search/api/
# BRAVE_API_KEY=
